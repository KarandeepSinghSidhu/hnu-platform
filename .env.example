# Local environment for the HNU Auckland site.  Copy this to `.env`:  cp .env.example .env
#
# How this file works:
#   - Fill in the required vars below.
#   - Optional URL/address vars are shown COMMENTED OUT. Leave them commented to use the
#     built-in default — assigning an empty string (e.g. FOO="") would OVERRIDE the default
#     with "" and break the fallback. Uncomment and set a real value only when you need to.
#   - The blank API-key vars (TRANSLATE_API_KEY, RESEND_API_KEY) are safe to leave empty;
#     empty simply means that feature is turned off.

# --- Required ---

# Prisma SQLite database path. Resolves relative to the working directory, so it MUST point
# at prisma/dev.db. "file:./dev.db" creates a SECOND, empty DB at the repo root and the app /
# media library look empty even after seeding. Keep this exactly as below.
DATABASE_URL="file:./prisma/dev.db"

# Admin login password for the admin console. Must be at least 12 characters;
# this "change-me" placeholder is rejected as too weak, so replace it before using /admin.
ADMIN_PASSWORD="change-me"

# Long random string (at least 32 characters) used to sign the admin session cookie.
# This placeholder is rejected — replace it, e.g. with `openssl rand -hex 32`.
ADMIN_SESSION_SECRET="replace-with-a-long-random-string"

# --- Public site URL (optional — defaults to http://localhost:3000 when unset) ---
# Set this to the deployed origin in production / preview; leave commented locally.
#   NEXT_PUBLIC_SITE_URL  canonical site URL for metadata/SEO  (src/lib/constants.ts)
# IMPORTANT: NEXT_PUBLIC_* vars are inlined at BUILD time, not read at runtime, so
# this must be the custom domain at/before the production build — it is baked into
# the canonical URLs, OpenGraph URLs, sitemap, robots Sitemap:/host:, and the
# .onrender.com -> custom-domain redirect. Changing it after the build has no effect.
# (Contrast: ALLOW_INDEXING is read at request time, so it can be flipped on launch
# day with a restart/redeploy.)
# NEXT_PUBLIC_SITE_URL="https://hnu.auckland.ac.nz"

# --- ORCID publications sync (optional) ---
# Defaults to the PRODUCTION public ORCID API (https://pub.orcid.org/v3.0), which needs no
# auth for public records. Uncomment to point at the sandbox for testing.
# ORCID_API_BASE_URL="https://pub.sandbox.orcid.org/v3.0"

# --- OpenAlex (optional — used during ORCID sync for per-paper affiliation data) ---
# A contact email opts into OpenAlex's faster, more reliable "polite pool".
# OPENALEX_MAILTO="you@example.com"
# Override the OpenAlex API base (defaults to https://api.openalex.org).
# OPENALEX_API_BASE_URL="https://api.openalex.org"

# --- Machine translation (optional — auto-translates non-study site copy to 中文) ---
# Leave TRANSLATE_API_KEY blank to keep translation OFF: the public site renders the fixed
# UI in 中文 (from src/messages) and falls back to English for admin-authored page copy.
# Translations are generated at publish / `npm run warm:translations` time and cached, so the
# public site never calls the API at view time. Provider: azure (default) | google | deepl.
TRANSLATE_PROVIDER="azure"
TRANSLATE_API_KEY=""
# Azure only: the resource region (e.g. australiaeast). Leave blank for a "Global" resource.
TRANSLATE_REGION=""
# Optional: override the provider's API host (tests / proxies / self-hosted).
TRANSLATE_ENDPOINT=""

# --- Contact-form email (Resend; optional) ---
# Leave RESEND_API_KEY blank to keep email OFF: contact submissions are still saved, the
# notification is just logged and skipped (no network calls in dev/CI).
RESEND_API_KEY=""
# The "from" address. Defaults to Resend's shared test sender (onboarding@resend.dev), which
# can only deliver to the email that owns your Resend account. For real delivery, uncomment
# and use an address on a domain you've verified in Resend.
# EMAIL_FROM="HNU Website <noreply@yourdomain>"
