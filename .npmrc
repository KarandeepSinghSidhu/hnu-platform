# Pin all installs in this repo to the official npm registry.
# Without this, a contributor whose global npm config uses a mirror (e.g.
# registry.npmmirror.com) embeds mirror URLs into package-lock.json, which then
# breaks `npm ci` in environments whose egress policy blocks that mirror
# (Claude cloud sessions) and makes Render builds depend on the mirror's uptime.
registry=https://registry.npmjs.org/
